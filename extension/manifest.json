{
  "manifest_version": 3,
  "name": "ACO - Cart Optimizer",
  "version": "1.1.1",
  "description": "ACO - Cart Optimizer. Optymalizuje zakupy i koszty wysyłki w serwisie Allegro.",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/logo.png",
    "default_title": "ACO - Cart Optimizer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.allegro.pl/*",
    "*://*.allegro.cz/*",
    "*://*.allegro.sk/*",
    "*://*.allegro.hu/*",
    "*://*.allegro.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.allegro.pl/*",
        "*://*.allegro.cz/*",
        "*://*.allegro.sk/*",
        "*://*.allegro.hu/*",
        "*://*.allegro.com/*"
      ],
      "js": [
        "config.production.js",
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/logo.png",
        "highs.wasm"
      ],
      "matches": [
        "*://*.allegro.pl/*",
        "*://*.allegro.cz/*",
        "*://*.allegro.sk/*",
        "*://*.allegro.hu/*",
        "*://*.allegro.com/*"
      ]
    }
  ]
}
